# Get a token from @BotFather.
BOT_TOKEN=1234567890:replace_with_your_telegram_bot_token

# Telegram numeric user ID allowed to open the admin panel.
ADMIN_ID=123456789

# One key or several comma-separated keys. Never commit real keys.
DEEPSEEK_API_KEYS=sk-replace_with_your_deepseek_api_key

# Optional overrides
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
